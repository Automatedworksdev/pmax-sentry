{
  "manifest_version": 3,
  "name": "PMax Sentry",
  "version": "3.0.0",
  "description": "Automatically identify and exclude low-quality YouTube placements in Performance Max campaigns - Now with secure proxy architecture",
  "permissions": [
    "sidePanel",
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://ads.google.com/*",
    "file:///*",
    "https://pmax-sentry-proxy-git-master-automatedworksdevs-projects.vercel.app/*"
  ],
  "action": {
    "default_title": "Click to open PMax Sentry"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://ads.google.com/*",
        "file:///*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}