{
  "manifest_version": 3,
  "name": "PMax Sentry",
  "version": "2.2.0",
  "description": "Automatically identify and exclude low-quality YouTube placements in Performance Max campaigns",
  "permissions": [
    "sidePanel",
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://ads.google.com/*",
    "https://*.supabase.co/*",
    "file:///*"
  ],
  "action": {
    "default_title": "Click to open PMax Sentry"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://ads.google.com/*",
        "file:///*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}